{
  "expo": {
    "name": "DeepDive AI",
    "slug": "deepdive-app",
    "version": "1.2.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "deepdiveai",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A1A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.deepdive.ai",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "DeepDive AI uses your microphone for voice research queries and video meetings.",
        "NSSpeechRecognitionUsageDescription": "DeepDive AI uses speech recognition to convert your spoken research queries to text.",
        "NSPhotoLibraryUsageDescription": "DeepDive AI needs access to your photos to attach images to chat messages.",
        "NSCameraUsageDescription": "DeepDive AI needs access to your camera for video meetings and profile photos.",
        "NSLocalNetworkUsageDescription": "DeepDive AI uses local network for WebRTC video calling in meetings.",
        "UIBackgroundModes": [
          "audio",
          "voip"
        ],
        "NSBonjourServices": [
          "_webrtc._tcp"
        ]
      },
      "associatedDomains": [
        "applinks:deepdive.app"
      ]
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png",
        "backgroundColor": "#0A0A1A"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.deepdive.ai",
      "permissions": [
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MICROPHONE",
        "android.permission.FOREGROUND_SERVICE_CAMERA",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.RECORD_AUDIO"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "deepdive.app",
              "pathPrefix": "/report"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        },
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "deepdiveai",
              "host": "report"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "DeepDive AI needs access to your photos to set your profile picture and attach images to chat messages.",
          "cameraPermission": "DeepDive AI needs access to your camera for video meetings and profile photos.",
          "microphonePermission": false
        }
      ],
      "expo-document-picker",
      [
        "expo-av",
        {
          "microphonePermission": "DeepDive AI uses your microphone for voice research queries and video meetings."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#6C63FF",
          "sounds": [],
          "androidMode": "default",
          "androidCollapsedTitle": "DeepDive AI"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": false,
            "compileSdkVersion": 35,
            "targetSdkVersion": 35
          },
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "publicReportBaseUrl": "https://deepdive.app/report",
      "appDeepLinkScheme": "deepdiveai://report",
      "router": {},
      "eas": {
        "projectId": "bb6c037c-6cf6-4a1f-8e75-8554c439928a"
      }
    }
  }
}
