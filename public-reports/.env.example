# Supabase — same project as the React Native app
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role — SERVER ONLY, never expose to client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI — for RAG chat
OPENAI_API_KEY=sk-...

# App URLs
NEXT_PUBLIC_APP_URL=https://your-public-reports-domain.com
DEEPDIVE_PLAY_STORE_URL=https://play.google.com/store/apps/deepdive-ai
NEXT_PUBLIC_DEEPDIVE_PLAY_STORE_URL=https://play.google.com/store/apps/deepdive-ai 
